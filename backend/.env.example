# --- OpenAI direct (si vous n'utilisez pas Azure) ---
# OPENAI_API_KEY=sk-...

# --- Azure OpenAI / Azure AI Foundry (prioritaire si ENDPOINT + API_KEY renseignés) ---
# URL de base (Foundry: ex. https://xxx.inference.ai.azure.com ou Cognitiveservices)
# AZURE_OPENAI_ENDPOINT=https://VOTRE-RESSOURCE.cognitiveservices.azure.com
# AZURE_OPENAI_API_KEY=votre-cle-azure
# Nom du déploiement : doit être EXACTEMENT celui affiché dans le portail Azure AI Foundry
# (Models > votre modèle > "Deployment name"). Sinon erreur 404 DeploymentNotFound.
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.2-chat
# ou AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.2-chat
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Modèles OpenAI (si pas Azure) ---
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Dossier de persistance Chroma (optionnel)
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_COLLECTION_NAME=documents

# RAG — le chat utilise les documents indexés (Chroma) pour répondre (défaut: true)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# TOP_K_RETRIEVE=4
# USE_RAG=true  (défaut) | USE_RAG=false pour chat sans base documentaire
